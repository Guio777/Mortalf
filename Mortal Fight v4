#esta clase esta pensada para manejar la defensa de los personajes, 
# con un sistema de escudo que se desgasta con cada ataque recibido y 
# una defensa balanceada que no es ni demasiado alta ni demasiado baja. 
# Ademas, el daño siempre sera al menos 1 para evitar ataques que no hagan nada.
class defensa():
    def __init__(self, defense):
        self.__defense = defense
        self.ataques_normales = 0     

# el uso de @property permite acceder a la defensa como un atributo normal, pero con la logica de validacion incluida en el setter. 
# Esto hace que el codigo sea mas limpio y facil de usar, ya que no es necesario llamar a un metodo por ejemplo def defensa() para obtener el valor de la defensa, 
# sino que se puede acceder directamente con player.defensa.
    @property  
    def defensa(self):
        return self.__defense  

    @property
    def escudo(self):
        return int(self.__defense)

# el setter de defensa incluye una validacion para evitar que la defensa sea negativa, 
# lo que podria causar problemas en el calculo del daño.
    @defensa.setter
    def defensa(self, nuevo_valor):
        if nuevo_valor < 0:
            raise ValueError("La defensa no puede ser negativa por que no tiene logica tener un escudo negativo jajaja")
        self.__defense = nuevo_valor

# la funcion recibir_ataque se encarga de calcular el daño recibido por el personaje, 
# teniendo en cuenta su defensa use np para ser mas preciso y efeciente en el calculo.
    def recibir_ataque(self, daño):
        # la defensa efectiva se calcula con una distribucion normal basada en la defensa actual del personaje,
        # pero con un factor de 0.3 para que no sea tan alta y el juego sea mas balanceado.
        defensa_efectiva = np.random.normal(self.__defense * 0.3)
        defensa_efectiva = max(0, defensa_efectiva)

        # esto evita que el daño sea sero para evitar que el juego no termine
        dano_real = max(1, daño - defensa_efectiva)

        # se aplica una reduccion aleatoria al daño real para agregar un poco de impredecibilidad al combate
        reduccion = np.random.uniform(0.85, 1.15)
        dano_final = int(dano_real * reduccion)

        # El escudo se desgasta con cada ataque hasta destruirce 
        self.__defense = max(0, self.__defense - daño * 0.2)

        self.health = max(0, self.health - dano_final)

        return dano_final



#Todas las clases son lo mismo con distinto diseño y todoas heredan la clase defensa solo que se llaman distinto 
# pero en si son lo mismo solo fue para darle mas estetica al juego y qie se vea mejor
class Melee(defensa):
    def __init__(self, name, health, attack_power, special_attack):
        #el super() se utiliza para llamar al constructor de la clase base defensa, 
        # lo que permite inicializar la defensa del personaje con un valor predeterminado de 100.
        super().__init__(100)
        self.name = name
        self.health = health
        self.attack_power = attack_power
        self.special_attack = special_attack

#la ffuncion atack se encarga de dar los dos ataques y ahi una condicion para 
# poder usar el especial que seria que nececitas haber hecho cuatro ataques normales 
# y cada personaje tiene un nombre unico de su ataque especial.
    def attack(self, opponent, tipo):
        if tipo == 1:
            damage = random.randint(0, self.attack_power)
            self.ataques_normales += 1
            print(f"{self.name} normal attack!")
        else:
            damage = random.randint(0, self.special_attack)
            self.ataques_normales = 0
            print(f"{self.name} SPECIAL attack!")

        daño_real = opponent.recibir_ataque(damage)
        print(f"{self.name} deals {daño_real} damage to {opponent.name}")

    #  sirve para verificar si el personaje sigue vivo en caso de ser menor que 0 pues el jugador esta bien tieso jajaja y el combate termina
    def is_alive(self):
        return self.health > 0


