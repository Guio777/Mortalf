# Aqui es donde use la recusrsividad para mejorar el cobate

#Esta funcion utuliza la recursividad para manejar el flujo de la pelea entre dos jugadores, alternando los turnos y verificando las condiciones de victoria después de cada ataque.
def fight_recursive(player1, player2):

    # if not es para verificar si el jugador esta vivo 
    if not player1.is_alive():
        print(f"{player1.name} has been defeated! {player2.name} wins!")
        mensaje_muerte(player1)
        return

    if not player2.is_alive():
        print(f"{player2.name} has been defeated! {player1.name} wins!")
        mensaje_muerte(player2)
        return

    # Turno del jugador 1
    print(f"\n{player1.name} (Vida: {player1.health} | Escudo: {player1.escudo})")
    print(f"Normales: {player1.ataques_normales}/4")

    try:
        tipo = int(input("1 = Normal, 2 = Especial: "))
    except:
        tipo = 1

    #es una condicio que puse para no solo usar el especial y hacer mas dinamico el juego
    if tipo == 2 and player1.ataques_normales < 4 or player1.health >= 100:
        print("Especial no disponible, usando normal")
        tipo = 1

    player1.attack(player2, tipo)

    # verifica si rl jugador esta vivo si no lo esta termina el combate y muestra el mensaje de la pelicula de "la mascara" de jim carrey
    if not player2.is_alive():
        print(f"{player2.name} has been defeated! {player1.name} wins!")
        mensaje_muerte(player2)
        return

    # turno del jugador 2
    print(f"\n{player2.name} (Vida: {player2.health} | Escudo: {player2.escudo})")
    print(f"Normales: {player2.ataques_normales}/4")

    try:
        tipo = int(input("1 = Normal, 2 = Especial: "))
    except:
        tipo = 1

    if tipo == 2 and player2.ataques_normales < 4 or player2.health >= 100:
        print("Especial no disponible, usando normal")
        tipo = 1

    player2.attack(player1, tipo)

    # Si el jugador no esta vivo termina la pelea y muestra el mensaje de muerte, si no sigue con la recursividad
    if not player1.is_alive():
        print(f"{player1.name} has been defeated! {player2.name} wins!")
        mensaje_muerte(player1)
        return

    
    fight_recursive(player1, player2)


